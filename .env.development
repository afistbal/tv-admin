VITE_APP_FLAG=dev
VITE_API_BASE_URL=https://test.yogoshort.com/api
VITE_API_PROXY_TARGET=https://test.yogoshort.com
# 活动日志等 C 端页面（默认代码内为 https://yogoshort.com）
VITE_PUBLIC_WEB_ORIGIN=https://yogoshort.com
# 影片列表封面 CDN 根（与旧站 config.static 一致，不配则列表不显示图）
# VITE_STATIC_ASSET_ORIGIN=

# --- 新增短剧 / Demo：COS 直传（GET oss/form）---
VITE_COS_UPLOAD_ENABLED=1
VITE_COS_UPLOAD_MODE=form
VITE_COS_OSS_FORM_PATH=oss/form
VITE_COS_KEY_PREFIX=add-movies
